# EmailJS public browser configuration
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_CONTACT_EMAIL=your_email@example.com

# Instagram Graph API private serverless configuration
# Do not prefix these with VITE_. They must stay server-side only.
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
INSTAGRAM_ACCESS_TOKEN=your_private_instagram_access_token
